{
  "name": "trading-journal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "npm run db:validate && npm run typecheck",
    "db:generate": "DATABASE_URL=file:./dev.db prisma generate",
    "db:validate": "DATABASE_URL=file:./dev.db prisma validate",
    "db:migrate": "DATABASE_URL=file:./dev.db node scripts/migrate.cjs",
    "db:seed": "DATABASE_URL=file:./dev.db tsx prisma/seed.ts",
    "db:reset": "rm -f prisma/dev.db && npm run db:migrate && npm run db:seed",
    "postinstall": "npm run db:generate"
  },
  "dependencies": {
    "@prisma/client": "^6.10.1",
    "next": "^15.3.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.1",
    "@types/react": "^19.1.7",
    "@types/react-dom": "^19.1.6",
    "prisma": "^6.10.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
